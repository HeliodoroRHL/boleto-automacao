PORT=3003
NODE_ENV=production

# JWT — gere uma string aleatória longa (min 32 chars)
JWT_SECRET=coloque_aqui_uma_chave_secreta_muito_longa_e_aleatoria

# Usuário administrador criado na primeira execução
ADMIN_EMAIL=admin@suaempresa.com.br
ADMIN_PASSWORD=SuaSenhaForte@123
ADMIN_NOME=Administrador

# API Asaas (conta padrão — opcional se usar múltiplas contas pela interface)
ASAAS_API_KEY=sua_chave_api_asaas
ASAAS_BASE_URL=https://api.asaas.com/v3

# SMTP padrão (opcional — pode configurar via interface web)
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=envio@seudominio.com.br
SMTP_PASS=sua_senha_smtp
SMTP_FROM=Financeiro <envio@seudominio.com.br>
